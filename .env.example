# Port the Express server listens on
PORT=3000

# Shared secret you set when creating the GitHub webhook.
# Used to verify the X-Hub-Signature-256 header on every incoming webhook.
GITHUB_WEBHOOK_SECRET=replace-me-with-a-long-random-string

# The label that marks an issue for remediation
DEVIN_LABEL=devin

# Postgres connection string.
# - On Render: auto-injected from the linked database (see render.yaml).
# - Locally: paste the Render database's EXTERNAL connection string here,
#   or point at a local Postgres.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Devin v3 API (service user auth — NOT the legacy key).
# Key starts with "cog_". Org ID scopes the /v3/organizations/{ORG_ID}/... routes.
DEVIN_API_KEY=cog_your_service_user_key
DEVIN_ORG_ID=your_org_id
# Base URL for the Devin API (override only if pointing at a different host).
DEVIN_API_BASE_URL=https://api.devin.ai

# Repository the workflow discovers + remediates issues in.
TARGET_REPO=ericyhliu/superset

# Tuning (all optional; sensible defaults shown).
WORKER_INTERVAL_MS=15000        # how often the worker drains queued tasks
MAX_CONCURRENT_SESSIONS=3       # max Devin remediation sessions in flight
SYNC_INTERVAL_MS=20000          # how often to poll Devin for progress/failures
WORKFLOW_INTERVAL_MS=3600000    # periodic discovery cadence (1h) when toggled on
