# Port the Express server listens on
PORT=3000

# Shared secret you set when creating the GitHub webhook.
# Used to verify the X-Hub-Signature-256 header on every incoming webhook.
GITHUB_WEBHOOK_SECRET=replace-me-with-a-long-random-string

# The label that marks an issue for remediation (slice 1 only logs it for now)
DEVIN_LABEL=devin

# Postgres connection string.
# - On Render: auto-injected from the linked database (see render.yaml).
# - Locally: paste the Render database's EXTERNAL connection string here,
#   or point at a local Postgres.
DATABASE_URL=postgres://user:password@host:5432/dbname
